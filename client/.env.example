# ============= DATABASE (Neon PostgreSQL) =============
# Get from: https://console.neon.tech
# Connection string: postgresql://user:password@ep-xxxx.us-east-1.neon.tech/neon?sslmode=require
DATABASE_URL="postgresql://user:password@ep-xxxx.region.neon.tech/neon?sslmode=require"

# Direct connection URL for Prisma migrations (optional, faster for local development)
# DIRECT_URL="postgresql://user:password@ep-xxxx.region.neon.tech/neon?sslmode=require"

# ============= CLERK AUTHENTICATION =============
# Get from: https://dashboard.clerk.com/apps
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxx
CLERK_SECRET_KEY=sk_test_xxxx
CLERK_WEBHOOK_SECRET=whsec_xxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ============= CLOUDFLARE R2 STORAGE =============
# Get from: https://dash.cloudflare.com/
NEXT_PUBLIC_R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
NEXT_PUBLIC_R2_BUCKET_NAME=kp-ams
# Format: https://bucket-name.your-account.r2.cloudflarestorage.com
NEXT_PUBLIC_R2_PUBLIC_URL=https://kp-ams.your-account.r2.cloudflarestorage.com

# ============= API & SERVICES =============
NEXT_PUBLIC_API_URL=http://localhost:3000
NODE_ENV=development

